# ─────────────────────────────────────────
# cTrader Open API
# ─────────────────────────────────────────
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCOUNT_ID=
CTRADER_HOST=demo.ctraderapi.com
CTRADER_PORT=5035
CTRADER_REDIRECT_URI=http://IP_DA_VPS:8080/callback
CTRADER_ACCESS_TOKEN=
CTRADER_REFRESH_TOKEN=

# ─────────────────────────────────────────
# Telegram — bot em @BotFather; chat_id em @userinfobot
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────
# Bot — Modo de operação
# ─────────────────────────────────────────
DRY_RUN=true
LOG_LEVEL=INFO

# ─────────────────────────────────────────
# Gestão de risco
# ─────────────────────────────────────────
RISK_PCT=1.0
# Lote máximo por ordem (1.0 = nunca mais que 1 lote). 0 = sem limite.
MAX_LOT=1.0

# ─────────────────────────────────────────
# Django Dashboard
# ─────────────────────────────────────────
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_PORT=9999

# ─────────────────────────────────────────
# Estratégias — ativar/desativar
# ─────────────────────────────────────────
STRATEGY_A_ENABLED=true
STRATEGY_B_ENABLED=true
STRATEGY_C_ENABLED=true
# true = Estratégia B abre o oposto (compra→vende, vende→compra)
STRATEGY_B_INVERT=false

# ─────────────────────────────────────────
# Trailing SL (proteger lucro)
# A 50% do TP → SL a 10% do TP | A 70% do TP → SL a 40% do TP
# ─────────────────────────────────────────
TRAIL_SL_ENABLED=true
TRAIL_CHECK_SECONDS=60

# ─────────────────────────────────────────
# Pares de moeda ativos
# ─────────────────────────────────────────
SYMBOLS=EURUSD,XAUUSD
